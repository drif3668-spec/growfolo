# ── Local development ──────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=sqlite:///./backend/growfolo.db
JWT_SECRET=change-me-in-production
RESEND_API_KEY=re_change_me
EMAIL_FROM=Growfolo <orders@growfolo.io>

# ── Vercel production (set these in the Vercel dashboard → Settings → Env Vars)
# APP_ENV=production
# DATABASE_URL=sqlite:////tmp/growfolo.db     ← ephemeral; migrate to Postgres for real persistence
# JWT_SECRET=<generate: openssl rand -hex 32>
# FRONTEND_URL=https://your-project.vercel.app
# RESEND_API_KEY=re_...
# EMAIL_FROM=Growfolo <orders@growfolo.io>
