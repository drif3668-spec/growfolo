# ═══════════════════════════════════════════════════════════════
#  Growfolo — Environment Variables Reference
#  Copy this file to .env and fill in the values.
#  NEVER commit a .env file with real secrets.
# ═══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
# production | development

# ── Database ───────────────────────────────────────────────────
# Development (SQLite — created automatically, no setup needed):
DATABASE_URL=sqlite:///./growfolo.db

# Production (PostgreSQL — Neon example):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# Generate a strong secret:  openssl rand -hex 32

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_change_me
# MAIL_FROM is the primary env var; EMAIL_FROM is also accepted as fallback
MAIL_FROM=Growfolo Support <support@growol.store>

# ── File uploads ───────────────────────────────────────────────
UPLOAD_DIR=uploads
